# Database configuration (defaults to in-memory H2 if not provided)
# DB_URL=jdbc:postgresql://localhost:5432/careerpilot
# DB_USER=postgres
# DB_PASSWORD=secretpassword
# DB_DRIVER=org.postgresql.Driver
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Gemini API Key (Required for live AI evaluations. If empty, the app uses realistic mock fallback data).
GEMINI_API_KEY=your_gemini_api_key_here
